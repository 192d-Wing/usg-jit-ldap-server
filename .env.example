# Database connection URL (overrides config.toml [database.url] if set)
DATABASE_URL=postgresql://ldap_server:changeme@localhost:5432/ldap_server

# Logging level — see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html
RUST_LOG=usg_jit_ldap_server=info,sqlx=warn
